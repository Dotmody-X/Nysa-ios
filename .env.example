# Copy this file to ".env" and fill in your own values.
# Never commit the real ".env" file.

# Supabase — get these from your project dashboard (Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI proxy (Phase 2+) — Claude API is called server-side via an Edge Function,
# the app only talks to the Edge Function, never to Anthropic directly.
EXPO_PUBLIC_AI_ENDPOINT=https://your-project.functions.supabase.co/ai
