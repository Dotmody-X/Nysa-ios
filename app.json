{
  "expo": {
    "name": "Nysa",
    "slug": "nysa",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nysa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nysa.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Nysa lit tes données de santé (sommeil, activité) pour les afficher dans ton pôle Bien-être.",
        "NSHealthUpdateUsageDescription": "Nysa peut enregistrer tes activités dans l'app Santé."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.nysa.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D6DA2F"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F9EF",
          "resizeMode": "contain"
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Nysa lit tes données de santé (sommeil, activité) pour ton pôle Bien-être.",
          "NSHealthUpdateUsageDescription": "Nysa peut enregistrer tes activités dans l'app Santé.",
          "background": false
        }
      ],
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
